{
  "sources": [],
  "target": {
    "table": "public.target_data",
    "credentials": {
      "password": "${DB_PASSWORD}"
    }
  },
  "pipeline_settings": {
    "schedule": "cron(0 0 * * ? *)",
    "retry_policy": {
      "max_retries": 3,
      "retry_interval": 300
    }
  },
  "retry_policies": {
    "max_retries": 3,
    "retry_interval": 300
  },
  "monitoring": {
    "enabled": true,
    "tool": "Prometheus",
    "alerts": {
      "job_failure": {
        "enabled": true,
        "threshold": 1
      },
      "data_quality": {
        "enabled": true,
        "threshold": 5
      }
    }
  },
  "schedule": "cron(0 0 * * ? *)"
}